[package]
name = "{{ project_name }}"
version = "0.1.0"
edition = "2021"

[lib]
crate-type = ["cdylib"]
path = "src/{{ rust_file_name }}"

[dependencies]
{% for dependency in dependencies %}
{% if dependency.json %}
{{ dependency.name }} = {{ dependency.json }}
{% else %}
{{ dependency.name }} = "{{ dependency.version }}"{% endif %}{% endfor %}

[build-dependencies]
{% for dependency in build_dependencies %}
{{ dependency.name }} = "{{ dependency.version }}"{% endfor %}

[workspace]